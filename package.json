{
  "name": "confluence-legacy-mcp-cli",
  "version": "0.1.0",
  "description": "External MCP server for Atlassian Confluence Server 6.0.x using legacy REST APIs, CQL, pages, spaces, comments, attachments, and labels.",
  "type": "module",
  "bin": {
    "confluence-legacy-mcp-cli": "./dist/index.js",
    "confluence-legacy-mcp-server": "./dist/index.js",
    "confluence-local-auth-proxy": "./dist/proxy-index.js"
  },
  "files": [
    "dist",
    "README.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "LICENSE",
    "docs",
    "examples"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "engines": {
    "node": ">=20.11"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist coverage",
    "dev": "tsx watch src/index.ts",
    "lint": "npm run typecheck",
    "pack:dry-run": "npm pack --dry-run",
    "prepack": "npm run clean && npm run build",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "confluence",
    "confluence-mcp",
    "confluence-server",
    "confluence-server-6",
    "confluence-server-6.0.5",
    "confluence-data-center",
    "confluence-legacy",
    "legacy-confluence",
    "on-prem-confluence",
    "self-hosted-confluence",
    "confluence-rest-api",
    "cql",
    "atlassian",
    "mcp",
    "mcp-server",
    "mcp-confluence",
    "model-context-protocol",
    "ai-agent",
    "claude-desktop",
    "claude-code",
    "cursor",
    "codex",
    "stdio",
    "typescript",
    "node"
  ],
  "author": "Ivelin Ivanov",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DevquasarX9/mcp-confluence-legacy.git"
  },
  "bugs": {
    "url": "https://github.com/DevquasarX9/mcp-confluence-legacy/issues"
  },
  "homepage": "https://github.com/DevquasarX9/mcp-confluence-legacy#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^16.4.7",
    "undici": "^7.13.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  },
  "packageManager": "npm@11.5.1"
}
