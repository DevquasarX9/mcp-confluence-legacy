# MCP server config. Point this at confluence-local-auth-proxy so upstream
# Confluence credentials stay out of the MCP server process.
CONFLUENCE_BASE_URL=http://127.0.0.1:4878
CONFLUENCE_AUTH_MODE=none

# Safe defaults
CONFLUENCE_READ_ONLY=true
CONFLUENCE_ENABLE_WRITE_TOOLS=false
CONFLUENCE_DRY_RUN=false

# Local auth proxy config. Run confluence-local-auth-proxy in a separate
# process with these variables.
CONFLUENCE_UPSTREAM_BASE_URL=https://confluence.example.com/confluence
CONFLUENCE_UPSTREAM_AUTH_MODE=basic
CONFLUENCE_UPSTREAM_USERNAME=your.username
CONFLUENCE_UPSTREAM_PASSWORD=your-password
CONFLUENCE_PROXY_HOST=127.0.0.1
CONFLUENCE_PROXY_PORT=4878
CONFLUENCE_PROXY_READ_ONLY=true
CONFLUENCE_PROXY_ENABLE_WRITE=false
CONFLUENCE_PROXY_ENABLE_ATTACHMENTS=false
CONFLUENCE_PROXY_STRICT_SSL=true
# CONFLUENCE_LOCAL_PROXY_TOKEN=replace-with-a-random-local-token

# Optional authentication modes
# Direct MCP basic auth keeps upstream credentials in the MCP server process.
# Prefer the local auth proxy unless you explicitly accept that risk.
# CONFLUENCE_AUTH_MODE=basic
# CONFLUENCE_USERNAME=your.username
# CONFLUENCE_PASSWORD=your-password
# CONFLUENCE_AUTH_MODE=bearer
# CONFLUENCE_TOKEN=token-from-proxy-or-newer-data-center
# CONFLUENCE_AUTH_MODE=header
# CONFLUENCE_AUTH_HEADER_NAME=X-Forwarded-User
# CONFLUENCE_AUTH_HEADER_VALUE=service-account
# CONFLUENCE_AUTH_MODE=cookie
# CONFLUENCE_COOKIE=JSESSIONID=...

# Optional network and safety settings
CONFLUENCE_STRICT_SSL=true
CONFLUENCE_TIMEOUT_MS=30000
CONFLUENCE_MAX_RESULTS=50
CONFLUENCE_MAX_RESPONSE_BYTES=1048576
CONFLUENCE_MAX_ATTACHMENT_BYTES=10485760
CONFLUENCE_LOG_LEVEL=info
CONFLUENCE_AUDIT_LOG=false

# Optional server-side policy filters
# CONFLUENCE_ALLOWED_SPACES=DEV,OPS
# CONFLUENCE_DENIED_SPACES=SECRET
# CONFLUENCE_CA_CERT_PATH=/absolute/path/to/ca.pem
